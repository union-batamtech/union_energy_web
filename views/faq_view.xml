<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_faq_tree" model="ir.ui.view">
        <field name="name">union_energy.faq.list</field>
        <field name="model">union_energy.faq</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <list string="FAQs">
                <field name="sequence"/>
                <field name="question"/>
                <field name="answer"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_faq_form" model="ir.ui.view">
        <field name="name">union_energy.faq.form</field>
        <field name="model">union_energy.faq</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="FAQ">
                <header/>
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <group>
                        <field name="sequence"/>
                        <field name="question"/>
                        <field name="answer"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_faq_search" model="ir.ui.view">
        <field name="name">union_energy.faq.search</field>
        <field name="model">union_energy.faq</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="FAQ">
                <field name="sequence"/>
                <field name="question"/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_faq_view">
        <field name="name">FAQs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">union_energy.faq</field>
        <field name="path">faq</field>
        <field name="binding_view_types">form</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_faq_search"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_faq_view_form">
        <field name="act_window_id" ref="act_open_faq_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_faq_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_faq_view_tree">
        <field name="act_window_id" ref="act_open_faq_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_faq_tree"/>
    </record>
</odoo>
