<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_all_faq">
        <field name="name">FAQ</field>
        <field name="description">Helps you manage your FAQ.</field>
        <field name="sequence">101</field>
        <field name="parent_id" eval="False"/>
    </record>

    <record id="module_category_union_energy_faq" model="res.groups.privilege">
        <field name="name">FAQ</field>
        <field name="description">Helps you manage your FAQ.</field>
        <field name="category_id" ref="faq.module_category_all_faq"/>
        <field name="sequence">1</field>
    </record>

    <record id="group_union_energy_faq_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="module_category_union_energy_faq"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids"
                eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_union_energy_faq_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="module_category_union_energy_faq"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        <field name="implied_ids"
                eval="[(4, ref('union_energy_web.group_union_energy_faq_user'))]"/>
    </record>
</odoo>
